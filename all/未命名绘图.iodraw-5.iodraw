<mxfile host="www.iodraw.com" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36 Edg/147.0.0.0" version="24.7.17">
  <diagram name="第 1 页" id="cLF-4u6-t-mjMcmnHHeJ">
    <mxGraphModel dx="786" dy="495" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="IV8wxGE8KKCTReJ84DcD-1" value="LLM" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="179" y="35" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-2" value="LLM（大模型）的本质：一个接收自然语言后输出自然语言的一个“接口”；其本质上不会参与实际的任何计算机的功能性操作。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="301" y="57" width="341" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-4" value="LLM" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="336" y="221" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-5" value="试想一下，当大模型的“智力”很高，也就是该大模型能处理更复杂的自然语言并输出无限趋近于精准的答案时，这个大模型可以做什么？" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="228.5" y="182" width="371" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-6" value="IQ_level: MAX" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontColor=#32d2c7;" vertex="1" parent="1">
          <mxGeometry x="454" y="246" width="119" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-8" value="" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;exitX=0.306;exitY=1.078;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0.477;entryY=-0.044;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="IV8wxGE8KKCTReJ84DcD-2" target="IV8wxGE8KKCTReJ84DcD-5">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="410" y="152" as="sourcePoint" />
            <mxPoint x="460" y="102" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-9" value="答案很显然：可以给它一个自然语言指令，让其输出稳定的对于程序来说的可读的指令，将指令喂给程序，程序返回结果，LLM读取结果，给予人自然语言回答。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="182" y="403" width="460" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-10" value="" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;exitX=0.306;exitY=1.078;exitDx=0;exitDy=0;exitPerimeter=0;entryX=0.477;entryY=-0.044;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="395.5" y="311" as="sourcePoint" />
            <mxPoint x="395.5" y="403" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-11" value="人" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="128" y="469" width="30" height="60" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-14" value="" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="IV8wxGE8KKCTReJ84DcD-11">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="231" y="518" as="sourcePoint" />
            <mxPoint x="313" y="499" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-15" value="你去帮我查一下明天的天气！" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#1396e7;" vertex="1" parent="1">
          <mxGeometry x="186" y="461" width="115" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-16" value="LLM" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="327" y="469" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-17" value="程序" style="html=1;whiteSpace=wrap;shape=isoCube2;backgroundOutline=1;isoAngle=15;" vertex="1" parent="1">
          <mxGeometry x="608" y="446" width="90" height="100" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-18" value="" style="endArrow=classic;html=1;rounded=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" target="IV8wxGE8KKCTReJ84DcD-17">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="456" y="496" as="sourcePoint" />
            <mxPoint x="540" y="564" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-19" value="call getweather(明天，上海)；" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#13d510;" vertex="1" parent="1">
          <mxGeometry x="430" y="459" width="184" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-20" value="" style="endArrow=classic;html=1;rounded=0;exitX=0;exitY=0;exitDx=0;exitDy=78.39291168278956;exitPerimeter=0;" edge="1" parent="1" source="IV8wxGE8KKCTReJ84DcD-17">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="461" y="657" as="sourcePoint" />
            <mxPoint x="460" y="524" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-21" value="return tomrrow_weather;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#11df29;" vertex="1" parent="1">
          <mxGeometry x="450" y="532" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-23" value="" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="310" y="527" as="sourcePoint" />
            <mxPoint x="163" y="527" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-24" value="我查到嘞，明天上海是晴天！" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#1c93ce;" vertex="1" parent="1">
          <mxGeometry x="179" y="529" width="163" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-26" value="" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="387" y="557" as="sourcePoint" />
            <mxPoint x="389" y="639" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-27" value="于是我们在这里引入一个Agent框架：ReAct(Reasoning Acting)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="250" y="654" width="292" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-28" value="你可以把LLM当作一个大脑来看，一个人需要完成一个工作是需要手脚并用的；LLM缺少的就是手和脚。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="712" width="219" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-30" value="Agent" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="342" y="751" width="111" height="127" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-33" value="LLM" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="371" y="745" width="53" height="39" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-34" value="?" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="418" y="732" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-35" value="现在把Agent当作一个人来看，人要端起来一杯水的动作是怎么完成的呢？：" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="533.75" y="710" width="207" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-36" value="1.大脑让手去握住杯子" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="505" y="758" width="195" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-37" value="2.手触碰到杯子后通过神经传输给大脑触感信号" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="542" y="790" width="253" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-38" value="3.大脑让手使劲握住杯子" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="505" y="822" width="207" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-39" value="4.手通过神经传输给大脑杯子的重量等信息" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="533.75" y="857" width="238.5" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-40" value="5.大脑感知到杯子被端起来了。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="533.75" y="887" width="185" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-41" value="整个动作完成！" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="599.5" y="920" width="107" height="30" as="geometry" />
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-42" value="" style="shape=flexArrow;endArrow=classic;html=1;rounded=0;" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="410" y="960" as="sourcePoint" />
            <mxPoint x="412" y="1055" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="IV8wxGE8KKCTReJ84DcD-43" value="你会发现，如人在干一件事时，本质上就像一个大循环：大脑发送指令，手动，大脑接收手返回的信息，思考下一步该干啥，该怎么调用自己的四肢。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="353" y="1079" width="414" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
